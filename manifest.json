{
  "name": "Convert price to USD",
  "description": "Chrome plugin for convert price to USD. Use with kolesa.kz",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://chalysh.pro/*",
    "https://kolesa.kz/*",
    "https://*.kolesa.kz/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kolesa.kz/*",
        "https://*.kolesa.kz/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
